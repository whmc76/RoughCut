{
  "name": "roughcut-workspace",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "bootstrap": "uv sync --extra dev && pnpm install",
    "setup": "uv run roughcut init",
    "doctor": "uv run roughcut doctor",
    "benchmark:reasoning": "uv run python scripts/benchmark_reasoning.py",
    "publication:preflight": "uv run python scripts/run_publication_preflight.py --require-tabs",
    "publication:preflight:json": "uv run python scripts/run_publication_preflight.py --require-tabs --output artifacts/publication-preflight.json",
    "migrate": "uv run roughcut migrate",
    "dev": "concurrently -k -n web,api,orchestrator,media,llm,agent -c magenta,cyan,yellow,green,blue,white \"pnpm dev:web\" \"pnpm dev:api\" \"pnpm dev:orchestrator\" \"pnpm dev:worker:media\" \"pnpm dev:worker:llm\" \"pnpm dev:worker:agent\"",
    "dev:web": "pnpm --dir frontend dev",
    "dev:api": "uv run roughcut api --reload",
    "dev:orchestrator": "uv run roughcut orchestrator",
    "dev:worker:media": "uv run roughcut worker --queue media_queue",
    "dev:worker:llm": "uv run roughcut worker --queue llm_queue",
    "dev:worker:agent": "uv run roughcut worker --queue agent_queue",
    "dev:publication-browser-agent": "node scripts/publication_browser_agent_service.mjs",
    "dev:watcher": "uv run roughcut watcher watch",
    "dev:telegram-agent": "uv run roughcut telegram-agent",
    "build": "pnpm run build:frontend",
    "build:frontend": "pnpm --dir frontend build",
    "build:backend": "uv run python -m py_compile src/roughcut/main.py src/roughcut/cli.py",
    "lint": "pnpm run lint:frontend && pnpm run lint:backend",
    "lint:frontend": "pnpm --dir frontend typecheck",
    "lint:backend": "uv run ruff check src",
    "docker:up": "pnpm docker:dev:up",
    "docker:down": "pnpm docker:dev:down",
    "docker:logs": "pnpm docker:dev:logs",
    "docker:infra:up": "docker compose --env-file roughcut.ports.env -f docker-compose.infra.yml up -d",
    "docker:infra:down": "docker compose --env-file roughcut.ports.env -f docker-compose.infra.yml down",
    "docker:infra:logs": "docker compose --env-file roughcut.ports.env -f docker-compose.infra.yml logs -f",
    "docker:dev:up": "pwsh -NoProfile -File start_roughcut.ps1 -Mode full",
    "docker:dev:rebuild": "pwsh -NoProfile -File start_roughcut.ps1 -Mode full -BuildDocker",
    "docker:dev:down": "pwsh -NoProfile -File start_roughcut.ps1 -Mode full-down",
    "docker:dev:logs": "docker compose --env-file roughcut.ports.env -f docker-compose.infra.yml -f docker-compose.runtime.yml -f docker-compose.dev.yml -f docker-compose.automation.yml logs -f",
    "docker:dev:autostart:install": "pwsh -NoProfile -File start_roughcut.ps1 -Mode install-autostart",
    "docker:dev:autostart:uninstall": "pwsh -NoProfile -File start_roughcut.ps1 -Mode uninstall-autostart",
    "docker:runtime:up": "pwsh -NoProfile -File start_roughcut.ps1 -Mode runtime",
    "docker:runtime:rebuild": "pwsh -NoProfile -File start_roughcut.ps1 -Mode runtime -BuildDocker",
    "docker:runtime:up:local-asr": "pwsh -NoProfile -File start_roughcut.ps1 -Mode runtime -DockerPythonExtras local-asr",
    "docker:runtime:auto-up": "pwsh -NoProfile -File start_roughcut.ps1 -Mode runtime -AutoDockerWatch",
    "docker:runtime:down": "pwsh -NoProfile -File start_roughcut.ps1 -Mode runtime-down",
    "docker:runtime:logs": "docker compose --env-file roughcut.ports.env -f docker-compose.infra.yml -f docker-compose.runtime.yml logs -f",
    "docker:runtime:refresh": "pwsh -NoProfile -File scripts/run-roughcut-docker-refresh-session.ps1 -ComposeMode runtime",
    "docker:runtime:watch": "pwsh -NoProfile -File scripts/watch-roughcut-docker-runtime.ps1 -ComposeMode runtime",
    "docker:runtime:watch:local-asr": "pwsh -NoProfile -File scripts/watch-roughcut-docker-runtime.ps1 -ComposeMode runtime -DockerPythonExtras local-asr",
    "docker:auto:up": "pwsh -NoProfile -File start_roughcut.ps1 -Mode full",
    "docker:auto:rebuild": "pwsh -NoProfile -File start_roughcut.ps1 -Mode full -BuildDocker",
    "docker:auto:up:local-asr": "pwsh -NoProfile -File start_roughcut.ps1 -Mode full -DockerPythonExtras local-asr",
    "docker:auto:auto-up": "pwsh -NoProfile -File start_roughcut.ps1 -Mode full -AutoDockerWatch",
    "docker:auto:down": "pwsh -NoProfile -File start_roughcut.ps1 -Mode full-down",
    "docker:auto:logs": "docker compose --env-file roughcut.ports.env -f docker-compose.infra.yml -f docker-compose.runtime.yml -f docker-compose.dev.yml -f docker-compose.automation.yml logs -f",
    "docker:auto:refresh": "pwsh -NoProfile -File scripts/run-roughcut-docker-refresh-session.ps1 -ComposeMode full",
    "docker:auto:watch": "pwsh -NoProfile -File scripts/watch-roughcut-docker-runtime.ps1 -ComposeMode full",
    "docker:auto:watch:local-asr": "pwsh -NoProfile -File scripts/watch-roughcut-docker-runtime.ps1 -ComposeMode full -DockerPythonExtras local-asr",
    "publication:release-gate": "uv run python scripts/run_publication_release_gate.py --require-tabs --output artifacts/publication-release-gate.json",
    "publication:release-gate:dry": "uv run python scripts/run_publication_release_gate.py --skip-backend-smoke --require-tabs --output artifacts/publication-release-gate.json",
    "publication:release-gate:published": "uv run python scripts/run_publication_release_gate.py --require-tabs --fake-agent-status published --contract-success-status published --output artifacts/publication-release-gate.json",
    "publication:release-gate:real": "uv run python scripts/run_publication_real_release_gate.py --require-tabs --output artifacts/publication-real-release-gate.json",
    "publication:autopilot": "uv run python scripts/run_publication_autopilot.py"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
