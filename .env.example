# Port configuration
# Keep local port assignments and dependent local URLs in roughcut.ports.env.
# This file is for credentials, model/provider choices, storage paths, and
# feature flags. Environment variables can still override both files.

# Unified host output root
ROUGHCUT_OUTPUT_HOST_ROOT=./data/runtime
ROUGHCUT_OUTPUT_ROOT=./data/runtime
ROUGHCUT_TEST_OUTPUT_ROOT=./data/runtime/tests

# Database
DATABASE_URL=postgresql+asyncpg://roughcut:roughcut@localhost:25432/roughcut
DB_POOL_SIZE=8
DB_MAX_OVERFLOW=8
DB_POOL_TIMEOUT_SEC=30
DB_POOL_RECYCLE_SEC=1800
DB_USE_NULL_POOL=false
ROUGHCUT_POSTGRES_PORT=25432

# Redis / Celery
REDIS_URL=redis://localhost:26379/0
CELERY_BROKER_URL=redis://localhost:26379/0
CELERY_RESULT_BACKEND=redis://localhost:26379/1
ROUGHCUT_REDIS_PORT=26379

# Job Storage (host filesystem, not Docker volume)
JOB_STORAGE_DIR=./data/runtime/jobs
CLEANUP_JOB_STORAGE_ON_TERMINAL=true
CLEANUP_RENDER_DEBUG_ON_TERMINAL=true
CLEANUP_HEYGEM_TEMP_ON_TERMINAL=true
ROUGHCUT_API_PORT=38471

# Local development keeps core infra preflight off, but external GPU services
# default to managed auto-release so shared ASR/TTS containers do not pin VRAM.
RUNTIME_PREFLIGHT_DOCKER_ENABLED=false
DOCKER_GPU_GUARD_ENABLED=true

# Transcription
TRANSCRIPTION_PROVIDER=local_http_asr
TRANSCRIPTION_MODEL=faster-whisper-large-v3-beam5-nohot
LOCAL_ASR_API_BASE_URL=http://127.0.0.1:30200
LOCAL_ASR_MODEL_NAME=faster-whisper-large-v3-beam5-nohot
LOCAL_ASR_DISPLAY_NAME=faster-whisper large-v3 beam5 nohot
LOCAL_ASR_HEALTH_PATH=/health
LOCAL_ASR_HOTWORDS_ENABLED=true
LOCAL_ASR_BEAM_SIZE=5
LOCAL_ASR_BEST_OF=5
LOCAL_ASR_CONDITION_ON_PREVIOUS_TEXT=false
LOCAL_ASR_VAD_FILTER=true
LOCAL_ASR_MAX_NEW_TOKENS=256
TRANSCRIPTION_CHUNK_THRESHOLD_SEC=300
TRANSCRIPTION_CHUNK_SIZE_SEC=300
TRANSCRIPTION_CHUNK_MIN_SEC=60
TRANSCRIPTION_CHUNK_OVERLAP_SEC=0
TRANSCRIPTION_CHUNK_REQUEST_TIMEOUT_SEC=900

# Reasoning
REASONING_PROVIDER=zhipu
REASONING_MODEL=glm-5.2
REASONING_EFFORT=low
LLM_ROUTING_MODE=bundled
HYBRID_ANALYSIS_PROVIDER=zhipu
HYBRID_ANALYSIS_MODEL=glm-5.2
HYBRID_ANALYSIS_EFFORT=low
HYBRID_ANALYSIS_SEARCH_MODE=entity_gated
HYBRID_COPY_PROVIDER=zhipu
HYBRID_COPY_MODEL=glm-5.2
HYBRID_COPY_EFFORT=max
HYBRID_COPY_SEARCH_MODE=follow_provider
MULTIMODAL_FALLBACK_PROVIDER=zhipu
MULTIMODAL_FALLBACK_MODEL=glm-4.6v-flash

# Search (Phase 2)
SEARCH_PROVIDER=searxng
SEARCH_FALLBACK_PROVIDER=searxng
SEARXNG_URL=http://localhost:8080

# API Keys
OPENAI_API_KEY=
OPENAI_AUTH_MODE=helper
OPENAI_API_KEY_HELPER=python scripts/print_codex_access_token.py
ROUGHCUT_OPENAI_AUTH_HELPER_KIND=codex
ROUGHCUT_CODEX_AUTH_HOST_DIR=C:/Users/28687/.codex
ANTHROPIC_API_KEY=
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_API_HOST=https://api.minimaxi.com
MINIMAX_CODING_PLAN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_CODING_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
ZHIPU_MCP_HTTP_BASE_URL=https://open.bigmodel.cn/api/mcp
ZHIPU_AUTH_MODE=api_key
ZHIPU_API_KEY_HELPER=
ZHIPU_SEARCH_ENGINE=search_pro
OLLAMA_BASE_URL=http://localhost:11434

# 智能发布封面图像生成
# 默认记录 Codex 内置 image_gen 请求清单；请求未完成时物料保持不可发布。
# 可选 backend：
# - codex_builtin
# - openai_images_api
# - minimax_images_api
# - dreamina_web
# `dreamina_web` 默认通过本仓库 vendored 的 Dreamina hybrid runner 运行。
# 如需覆盖 runner 模块路径，再设置 INTELLIGENT_COPY_COVER_DREAMINA_RUNNER_SCRIPT。
INTELLIGENT_COPY_COVER_IMAGE_BACKEND=codex_builtin
INTELLIGENT_COPY_COVER_IMAGE_MODEL=image2
INTELLIGENT_COPY_COVER_IMAGE_QUALITY=medium
INTELLIGENT_COPY_COVER_DREAMINA_COMMAND=node
INTELLIGENT_COPY_COVER_DREAMINA_RUNNER_SCRIPT=
INTELLIGENT_COPY_COVER_DREAMINA_CDP_BASE_URL=http://127.0.0.1:9222
INTELLIGENT_COPY_COVER_DREAMINA_COOKIE_SOURCE_BASE_URL=http://127.0.0.1:9222
INTELLIGENT_COPY_COVER_DREAMINA_PAGE_URL=https://jimeng.jianying.com/ai-tool/generate/?type=image
INTELLIGENT_COPY_COVER_DREAMINA_PAGE_URL_PATTERN=jimeng.jianying.com/ai-tool/generate
INTELLIGENT_COPY_COVER_DREAMINA_USER_DATA_DIR=C:/Users/Administrator/AppData/Local/HydraDreaminaCDPProfile
INTELLIGENT_COPY_COVER_DREAMINA_HEADLESS_USER_DATA_DIR=C:/Users/Administrator/AppData/Local/HydraDreaminaCDPProfileHeadless
INTELLIGENT_COPY_COVER_DREAMINA_TEMPLATE_PATH=
INTELLIGENT_COPY_COVER_DREAMINA_SUBMIT_STATE_PATH=
INTELLIGENT_COPY_COVER_DREAMINA_EXECUTABLE_PATH=
INTELLIGENT_COPY_COVER_DREAMINA_HTTP_REPLAY_ENABLED=true
INTELLIGENT_COPY_COVER_DREAMINA_AUTO_LAUNCH=true
INTELLIGENT_COPY_COVER_DREAMINA_HEADLESS=true
INTELLIGENT_COPY_COVER_DREAMINA_KEEP_ALIVE=false
INTELLIGENT_COPY_COVER_DREAMINA_POLL_INTERVAL_MS=5000
INTELLIGENT_COPY_COVER_DREAMINA_POLL_TIMEOUT_MS=300000
INTELLIGENT_COPY_COVER_DREAMINA_SUBMIT_TIMEOUT_MS=60000
INTELLIGENT_COPY_COVER_DREAMINA_CAPTURE_TIMEOUT_MS=120000
INTELLIGENT_COPY_COVER_DREAMINA_MIN_SUBMIT_INTERVAL_MS=45000

# HeyGem / 数字人口播
AVATAR_API_BASE_URL=http://127.0.0.1:49202
AVATAR_TRAINING_API_BASE_URL=http://127.0.0.1:49204
HEYGEM_API_PORT=49202
HEYGEM_SHARED_HOST_DIR=D:/duix_avatar_data/face2face
HEYGEM_SHARED_ROOT=D:/duix_avatar_data/face2face
HEYGEM_VOICE_ROOT=D:/duix_avatar_data/face2face/voice/data
VOICE_PROVIDER=runninghub
VOICE_CLONE_API_BASE_URL=https://www.runninghub.cn
VOICE_CLONE_VOICE_ID=2003864334474354690
COSYVOICE3_TTS_API_BASE_URL=http://127.0.0.1:30180
COSYVOICE3_TTS_HEALTH_PATH=/health
COSYVOICE3_TTS_PORT=30180
COSYVOICE3_BASE_IMAGE=roughcut-moss-audio:local
COSYVOICE3_MODEL_ID=FunAudioLLM/Fun-CosyVoice3-0.5B-2512
COSYVOICE3_DOWNLOAD_BACKEND=huggingface
HF_ENDPOINT=https://hf-mirror.com
HF_HUB_DISABLE_XET=1
HF_HUB_DOWNLOAD_TIMEOUT=600
COSYVOICE3_MODEL_CACHE=E:/WorkSpace/RoughCut/.model-cache/cosyvoice3
COSYVOICE3_FP16=1
COSYVOICE3_LOAD_VLLM=
COSYVOICE3_LOAD_TRT=
MOSS_TTS_LOCAL_API_BASE_URL=http://127.0.0.1:30191
MOSS_TTS_LOCAL_HEALTH_PATH=/health
MOSS_TTS_LOCAL_PORT=30191
MOSS_TTS_LOCAL_MODEL_ID=OpenMOSS-Team/MOSS-TTS-Local-Transformer
MOSS_TTS_LOCAL_MODELSCOPE_MODEL_ID=OpenMOSS/MOSS-TTS-Local-Transformer
MOSS_TTS_LOCAL_DOWNLOAD_BACKEND=modelscope
MOSS_TTS_LOCAL_HF_ENDPOINT=https://huggingface.co
MOSS_TTS_LOCAL_MODEL_CACHE=E:/WorkSpace/RoughCut/.model-cache/moss-tts-local
HEYGEM_DOCKER_RUNTIME=runc
HEYGEM_ENABLE_CUDA=false
HEYGEM_CUDA_VERSION=13.0
HEYGEM_TORCH_INDEX_URL=https://download.pytorch.org/whl/cu130
HEYGEM_TORCH_VERSION=
HEYGEM_GPU_VISIBLE_DEVICES=all

# Managed local GPU service lifecycle
RUNTIME_PREFLIGHT_DOCKER_ENABLED=false
DOCKER_GPU_GUARD_ENABLED=true
DOCKER_GPU_GUARD_IDLE_TIMEOUT_SEC=900
LOCAL_ASR_DOCKER_GUARD_ENABLED=true
LOCAL_ASR_DOCKER_COMPOSE_FILE=E:/WorkSpace/RoughCut/docker-compose.asr-matrix.yml
LOCAL_ASR_DOCKER_ENV_FILE=
LOCAL_ASR_DOCKER_SERVICES=faster-whisper-large-v3
LOCAL_ASR_DOCKER_IDLE_TIMEOUT_SEC=10
COSYVOICE3_TTS_DOCKER_GUARD_ENABLED=true
COSYVOICE3_TTS_DOCKER_COMPOSE_FILE=E:/WorkSpace/RoughCut/docker-compose.cosyvoice3.yml
COSYVOICE3_TTS_DOCKER_ENV_FILE=
COSYVOICE3_TTS_DOCKER_SERVICES=cosyvoice3-tts
COSYVOICE3_TTS_DOCKER_IDLE_TIMEOUT_SEC=10
MOSS_TTS_LOCAL_DOCKER_GUARD_ENABLED=true
MOSS_TTS_LOCAL_DOCKER_COMPOSE_FILE=E:/WorkSpace/RoughCut/docker-compose.moss-tts-local.yml
MOSS_TTS_LOCAL_DOCKER_ENV_FILE=
MOSS_TTS_LOCAL_DOCKER_SERVICES=moss-tts-local
MOSS_TTS_LOCAL_DOCKER_IDLE_TIMEOUT_SEC=10
HEYGEM_DOCKER_GUARD_ENABLED=true
HEYGEM_DOCKER_COMPOSE_FILE=E:/WorkSpace/heygem/docker-compose.yml
HEYGEM_DOCKER_ENV_FILE=E:/WorkSpace/heygem/.env
HEYGEM_DOCKER_SERVICES=heygem
HEYGEM_DOCKER_IDLE_TIMEOUT_SEC=900
INDEXTTS2_DOCKER_GUARD_ENABLED=false
INDEXTTS2_DOCKER_COMPOSE_FILE=E:/WorkSpace/indextts2-service/docker-compose.yml
INDEXTTS2_DOCKER_ENV_FILE=E:/WorkSpace/indextts2-service/.env
INDEXTTS2_DOCKER_SERVICES=indextts2
INDEXTTS2_DOCKER_IDLE_TIMEOUT_SEC=10

# Publication / browser-agent
PUBLICATION_BROWSER_AGENT_BASE_URL=http://127.0.0.1:49310
PUBLICATION_BROWSER_AGENT_AUTH_TOKEN=
PUBLICATION_BROWSER_CDP_URL=http://127.0.0.1:9222
PUBLICATION_BROWSER=chrome
PUBLICATION_BROWSER_USER_DATA_DIR=
PUBLICATION_BROWSER_PROFILE_DIRECTORY=
PUBLICATION_BROWSER_ALLOW_TAB_AUTOCREATE=false
PUBLICATION_WORKER_POLL_INTERVAL_SEC=30
PUBLICATION_WORKER_BATCH_LIMIT=5
PUBLICATION_ATTEMPT_LEASE_SEC=300
PUBLICATION_BROWSER_AGENT_TIMEOUT_SEC=60

# Security
MAX_UPLOAD_SIZE_MB=2048
MAX_VIDEO_DURATION_SEC=7200
FFMPEG_TIMEOUT_SEC=600
ALLOWED_EXTENSIONS=.mp4,.mov,.mkv,.avi,.webm

# Output
OUTPUT_DIR=./data/runtime/output
RENDER_DEBUG_DIR=./data/runtime/render-debug
PACKAGING_ASSET_DIR=assets/packaging
PACKAGING_ASSET_STORAGE_BACKEND=local
PREFERRED_UI_LANGUAGE=zh-CN
TELEGRAM_AGENT_ENABLED=false
TELEGRAM_AGENT_CLAUDE_ENABLED=false
TELEGRAM_AGENT_CLAUDE_COMMAND=claude
TELEGRAM_AGENT_CLAUDE_MODEL=opus
TELEGRAM_AGENT_CODEX_COMMAND=codex
TELEGRAM_AGENT_CODEX_MODEL=gpt-5.5
TELEGRAM_AGENT_ACP_COMMAND=
TELEGRAM_AGENT_TASK_TIMEOUT_SEC=900
TELEGRAM_AGENT_RESULT_MAX_CHARS=3500
TELEGRAM_AGENT_STATE_DIR=./data/runtime/telegram-agent
TELEGRAM_REMOTE_REVIEW_ENABLED=false
TELEGRAM_BOT_API_BASE_URL=https://api.telegram.org
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_CHAT_ID=
ROUGHCUT_ACP_BRIDGE_BACKEND=codex
ROUGHCUT_ACP_BRIDGE_FALLBACK_BACKEND=claude
ROUGHCUT_ACP_BRIDGE_CLAUDE_MODEL=opus
ROUGHCUT_ACP_BRIDGE_CODEX_COMMAND=codex
ROUGHCUT_ACP_BRIDGE_CODEX_MODEL=gpt-5.5

# Automation
AUTO_CONFIRM_CONTENT_PROFILE=true
CONTENT_PROFILE_REVIEW_THRESHOLD=0.72
AUTO_ACCEPT_GLOSSARY_CORRECTIONS=true
GLOSSARY_CORRECTION_REVIEW_THRESHOLD=0.9
AUTO_SELECT_COVER_VARIANT=true
COVER_SELECTION_REVIEW_GAP=0.08
INTELLIGENT_COPY_COVER_IMAGE_GENERATION_ENABLED=true
INTELLIGENT_COPY_COVER_IMAGE_BACKEND=codex_builtin
INTELLIGENT_COPY_COVER_IMAGE_MODEL=image2
INTELLIGENT_COPY_COVER_IMAGE_QUALITY=medium
INTELLIGENT_COPY_COVER_IMAGE_TIMEOUT_SEC=90
PACKAGING_SELECTION_REVIEW_GAP=0.08
PACKAGING_SELECTION_MIN_SCORE=0.6
STREAMLINED_ASR_PIPELINE_ENABLED=true
