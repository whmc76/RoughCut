# Unified host output root
ROUGHCUT_OUTPUT_HOST_ROOT=F:/roughcut_outputs
ROUGHCUT_OUTPUT_ROOT=F:/roughcut_outputs
ROUGHCUT_TEST_OUTPUT_ROOT=F:/roughcut_outputs/tests

# Database
DATABASE_URL=postgresql+asyncpg://roughcut:roughcut@localhost:25432/roughcut
DB_POOL_SIZE=8
DB_MAX_OVERFLOW=8
DB_POOL_TIMEOUT_SEC=30
DB_POOL_RECYCLE_SEC=1800
ROUGHCUT_POSTGRES_PORT=25432

# Redis / Celery
REDIS_URL=redis://localhost:26379/0
CELERY_BROKER_URL=redis://localhost:26379/0
CELERY_RESULT_BACKEND=redis://localhost:26379/1
ROUGHCUT_REDIS_PORT=26379

# Job Storage (host filesystem, not Docker volume)
JOB_STORAGE_DIR=F:/roughcut_outputs/jobs
CLEANUP_JOB_STORAGE_ON_TERMINAL=true
CLEANUP_RENDER_DEBUG_ON_TERMINAL=true
CLEANUP_HEYGEM_TEMP_ON_TERMINAL=true
ROUGHCUT_API_PORT=38471

# Local development must not implicitly start Docker services.
# Set these to true only for explicit Docker-managed dependency mode.
RUNTIME_PREFLIGHT_DOCKER_ENABLED=false
DOCKER_GPU_GUARD_ENABLED=false

# Transcription
TRANSCRIPTION_PROVIDER=local_http_asr
TRANSCRIPTION_MODEL=qwen3-asr-1.7b-forced-aligner
LOCAL_ASR_API_BASE_URL=http://127.0.0.1:30080
LOCAL_ASR_MODEL_NAME=qwen3-asr-1.7b-forced-aligner
LOCAL_ASR_DISPLAY_NAME=Qwen3-ASR 1.7B + ForcedAligner
LOCAL_ASR_HEALTH_PATH=/health
QWEN3_ASR_PORT=30080
QWEN3_ASR_HF_CACHE=F:/cache_redirects/.cache/huggingface
QWEN3_ASR_IDLE_UNLOAD_SECONDS=10

# Reasoning
REASONING_PROVIDER=openai
REASONING_MODEL=gpt-5.5
REASONING_EFFORT=medium
LLM_ROUTING_MODE=hybrid_performance
HYBRID_ANALYSIS_PROVIDER=openai
HYBRID_ANALYSIS_MODEL=gpt-5.5
HYBRID_ANALYSIS_EFFORT=medium
HYBRID_ANALYSIS_SEARCH_MODE=follow_provider
HYBRID_COPY_PROVIDER=openai
HYBRID_COPY_MODEL=gpt-5.4-mini
HYBRID_COPY_EFFORT=high
HYBRID_COPY_SEARCH_MODE=follow_provider
MULTIMODAL_FALLBACK_PROVIDER=openai
MULTIMODAL_FALLBACK_MODEL=gpt-5.4-mini

# Search (Phase 2)
SEARCH_PROVIDER=auto
SEARCH_FALLBACK_PROVIDER=openai
SEARXNG_URL=http://localhost:8080

# API Keys
OPENAI_API_KEY=
OPENAI_AUTH_MODE=helper
OPENAI_API_KEY_HELPER=python scripts/print_codex_access_token.py
ROUGHCUT_OPENAI_AUTH_HELPER_KIND=codex
ROUGHCUT_CODEX_AUTH_HOST_DIR=C:/Users/28687/.codex
ANTHROPIC_API_KEY=
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_API_HOST=https://api.minimaxi.com
MINIMAX_CODING_PLAN_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# HeyGem / 数字人口播
AVATAR_API_BASE_URL=http://127.0.0.1:49202
AVATAR_TRAINING_API_BASE_URL=http://127.0.0.1:49204
HEYGEM_API_PORT=49202
HEYGEM_SHARED_HOST_DIR=F:/roughcut_outputs/heygem
HEYGEM_SHARED_ROOT=F:/roughcut_outputs/heygem
HEYGEM_VOICE_ROOT=F:/roughcut_outputs/voice_refs
VOICE_PROVIDER=runninghub
VOICE_CLONE_API_BASE_URL=https://www.runninghub.cn
VOICE_CLONE_VOICE_ID=2003864334474354690
COSYVOICE3_TTS_API_BASE_URL=http://127.0.0.1:30180
COSYVOICE3_TTS_HEALTH_PATH=/health
COSYVOICE3_TTS_PORT=30180
COSYVOICE3_BASE_IMAGE=roughcut-moss-audio:local
COSYVOICE3_MODEL_ID=FunAudioLLM/Fun-CosyVoice3-0.5B-2512
COSYVOICE3_DOWNLOAD_BACKEND=huggingface
HF_ENDPOINT=https://hf-mirror.com
HF_HUB_DISABLE_XET=1
HF_HUB_DOWNLOAD_TIMEOUT=600
COSYVOICE3_MODEL_CACHE=F:/roughcut_outputs/model-cache/cosyvoice3
COSYVOICE3_FP16=1
COSYVOICE3_LOAD_VLLM=
COSYVOICE3_LOAD_TRT=
HEYGEM_DOCKER_RUNTIME=runc
HEYGEM_ENABLE_CUDA=false
HEYGEM_CUDA_VERSION=13.0
HEYGEM_TORCH_INDEX_URL=https://download.pytorch.org/whl/cu130
HEYGEM_TORCH_VERSION=
HEYGEM_GPU_VISIBLE_DEVICES=all

# Managed local GPU service lifecycle
RUNTIME_PREFLIGHT_DOCKER_ENABLED=false
DOCKER_GPU_GUARD_ENABLED=false
DOCKER_GPU_GUARD_IDLE_TIMEOUT_SEC=900
LOCAL_ASR_DOCKER_GUARD_ENABLED=true
LOCAL_ASR_DOCKER_COMPOSE_FILE=E:/WorkSpace/RoughCut/docker-compose.qwen3-asr.yml
LOCAL_ASR_DOCKER_ENV_FILE=
LOCAL_ASR_DOCKER_SERVICES=qwen3-asr
LOCAL_ASR_DOCKER_IDLE_TIMEOUT_SEC=900
COSYVOICE3_TTS_DOCKER_GUARD_ENABLED=true
COSYVOICE3_TTS_DOCKER_COMPOSE_FILE=E:/WorkSpace/RoughCut/docker-compose.cosyvoice3.yml
COSYVOICE3_TTS_DOCKER_ENV_FILE=
COSYVOICE3_TTS_DOCKER_SERVICES=cosyvoice3-tts
COSYVOICE3_TTS_DOCKER_IDLE_TIMEOUT_SEC=900
HEYGEM_DOCKER_GUARD_ENABLED=true
HEYGEM_DOCKER_COMPOSE_FILE=E:/WorkSpace/heygem/docker-compose.yml
HEYGEM_DOCKER_ENV_FILE=E:/WorkSpace/heygem/.env
HEYGEM_DOCKER_SERVICES=heygem
HEYGEM_DOCKER_IDLE_TIMEOUT_SEC=900
INDEXTTS2_DOCKER_GUARD_ENABLED=true
INDEXTTS2_DOCKER_COMPOSE_FILE=E:/WorkSpace/indextts2-service/docker-compose.yml
INDEXTTS2_DOCKER_ENV_FILE=E:/WorkSpace/indextts2-service/.env
INDEXTTS2_DOCKER_SERVICES=indextts2
INDEXTTS2_DOCKER_IDLE_TIMEOUT_SEC=900

# Publication / browser-agent
PUBLICATION_BROWSER_AGENT_BASE_URL=http://127.0.0.1:49310
PUBLICATION_BROWSER_AGENT_AUTH_TOKEN=
PUBLICATION_WORKER_POLL_INTERVAL_SEC=30
PUBLICATION_WORKER_BATCH_LIMIT=5
PUBLICATION_ATTEMPT_LEASE_SEC=300
PUBLICATION_BROWSER_AGENT_TIMEOUT_SEC=60

# Security
MAX_UPLOAD_SIZE_MB=2048
MAX_VIDEO_DURATION_SEC=7200
FFMPEG_TIMEOUT_SEC=600
ALLOWED_EXTENSIONS=.mp4,.mov,.mkv,.avi,.webm

# Output
OUTPUT_DIR=F:/roughcut_outputs/output
RENDER_DEBUG_DIR=F:/roughcut_outputs/render-debug
PACKAGING_ASSET_DIR=assets/packaging
PACKAGING_ASSET_STORAGE_BACKEND=local
PREFERRED_UI_LANGUAGE=zh-CN
TELEGRAM_AGENT_ENABLED=false
TELEGRAM_AGENT_CLAUDE_ENABLED=false
TELEGRAM_AGENT_CLAUDE_COMMAND=claude
TELEGRAM_AGENT_CLAUDE_MODEL=opus
TELEGRAM_AGENT_CODEX_COMMAND=codex
TELEGRAM_AGENT_CODEX_MODEL=gpt-5.4-mini
TELEGRAM_AGENT_ACP_COMMAND=
TELEGRAM_AGENT_TASK_TIMEOUT_SEC=900
TELEGRAM_AGENT_RESULT_MAX_CHARS=3500
TELEGRAM_AGENT_STATE_DIR=F:/roughcut_outputs/telegram-agent
TELEGRAM_REMOTE_REVIEW_ENABLED=false
TELEGRAM_BOT_API_BASE_URL=https://api.telegram.org
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_CHAT_ID=
ROUGHCUT_ACP_BRIDGE_BACKEND=codex
ROUGHCUT_ACP_BRIDGE_FALLBACK_BACKEND=claude
ROUGHCUT_ACP_BRIDGE_CLAUDE_MODEL=opus
ROUGHCUT_ACP_BRIDGE_CODEX_COMMAND=codex
ROUGHCUT_ACP_BRIDGE_CODEX_MODEL=gpt-5.4-mini

# Automation
AUTO_CONFIRM_CONTENT_PROFILE=true
CONTENT_PROFILE_REVIEW_THRESHOLD=0.72
AUTO_ACCEPT_GLOSSARY_CORRECTIONS=true
GLOSSARY_CORRECTION_REVIEW_THRESHOLD=0.9
AUTO_SELECT_COVER_VARIANT=true
COVER_SELECTION_REVIEW_GAP=0.08
PACKAGING_SELECTION_REVIEW_GAP=0.08
PACKAGING_SELECTION_MIN_SCORE=0.6
