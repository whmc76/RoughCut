{
  "manifest_version": 3,
  "name": "RoughCut Publication Bridge",
  "version": "0.1.7",
  "description": "Expose the real logged-in Chrome session to the RoughCut publication browser-agent via chrome.debugger.",
  "permissions": [
    "alarms",
    "contentSettings",
    "debugger",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "RoughCut Publication Bridge"
  }
}
